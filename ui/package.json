{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "electron:launch": "cross-env ELECTRON_RENDERER_URL=http://localhost:5173 ELECTRON_STARTUP=dev node ./scripts/launch-electron.cjs",
    "dev:electron": "concurrently -k \"npm:dev\" \"wait-on http://localhost:5173 && npm run electron:launch\"",
    "build:electron": "npm run build && cross-env NODE_ENV=production electron-builder",
    "dev:no-typecheck": "TSC_CHECK=false vite",
    "dev:watch": "nodemon",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=200",
    "preview": "vite preview",
    "test:e2e": "NODE_OPTIONS='--max-old-space-size=8192' npx playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:api": "node node_modules/.bin/jest e2e/api-integration-pactum.spec.ts",
    "test:api:watch": "node node_modules/.bin/jest e2e/api-integration-pactum.spec.ts --watch",
    "test:api:verbose": "node node_modules/.bin/jest e2e/api-integration-pactum.spec.ts --verbose",
    "test": "node node_modules/.bin/jest",
    "test:watch": "node node_modules/.bin/jest --watch",
    "test:coverage": "node node_modules/.bin/jest --coverage",
    "test:ui": "node node_modules/.bin/jest --watch",
    "duplication-check": "npx jscpd src/ || echo \"Duplication found but within acceptable threshold\"",
    "test:cucumber": "cucumber-js",
    "test:cucumber:html": "cucumber-js --format html:reports/cucumber-report.html",
    "test:cucumber:debug": "cucumber-js --fail-fast",
    "test:bdd": "npm run test:cucumber",
    "generate:steps": "tsx scripts/generate-step-definitions.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.84.1",
    "axios": "^1.12.0",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "fancy-ansi": "^0.1.3",
    "lucide-react": "^0.537.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.7.1",
    "react-use-measure": "^2.1.7",
    "react-virtuoso": "^4.14.0",
    "react-window": "^1.8.11",
    "recharts": "^3.1.2",
    "rfc6902": "^5.1.2",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@cucumber/cucumber-expressions": "^18.0.1",
    "@cucumber/gherkin": "^34.0.0",
    "@cucumber/gherkin-streams": "^5.0.1",
    "@eslint/js": "^9.32.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.0.0",
    "electron-builder": "^25.1.7",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.1.2",
    "jscpd": "^4.0.5",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.10",
    "pactum": "^3.8.0",
    "postcss": "^8.5.6",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codegoat.desktop",
    "productName": "CodeGoat Desktop",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}

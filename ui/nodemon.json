{
  "exec": "vite",
  "ext": "js,jsx,ts,tsx,html,css,json",
  "ignore": ["dist/*", "node_modules/*", "build/*", ".git/*"],
  "env": {
    "NODE_ENV": "development"
  },
  "verbose": true,
  "delay": "1000",
  "watch": ["src", "index.html", "vite.config.ts", "tailwind.config.js", "postcss.config.js"]
}
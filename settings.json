{
  "fallback": {
    "maxRetries": 5,
    "retryDelay": 1000,
    "enableFallbacks": true,
    "fallbackOnContextLength": true,
    "fallbackOnRateLimit": true,
    "fallbackOnServerError": false
  },
  "validation": {
    "stages": [
      {
        "id": "lint",
        "name": "Code Linting",
        "command": "npm run lint",
        "timeout": 90000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 1
      },
      {
        "id": "typecheck",
        "name": "Type Checking",
        "command": "npm run type-check",
        "timeout": 90000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 2
      },
      {
        "id": "unit-tests-backend",
        "name": "Backend Unit Tests",
        "command": "npm run test:unit:backend",
        "timeout": 120000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 3
      },
      {
        "id": "unit-tests-frontend",
        "name": "Frontend Unit Tests",
        "command": "cd ui && npm test -- --watchAll=false --no-watch --passWithNoTests --testTimeout=30000 --maxWorkers=2",
        "timeout": 180000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 4
      },
      {
        "id": "coverage-frontend",
        "name": "Frontend Coverage Check",
        "command": "cd ui && npm test -- --coverage --maxWorkers=2 --testTimeout=30000 --watchAll=false",
        "timeout": 180000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 5
      },
      {
        "id": "coverage-backend",
        "name": "Backend Coverage Check",
        "command": "npm run test:coverage:backend",
        "timeout": 120000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 6
      },
      {
        "id": "unit-tests-scripts",
        "name": "Scripts Unit Tests",
        "command": "npm run test:unit:scripts",
        "timeout": 120000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 7
      },
      {
        "id": "integration-tests",
        "name": "Integration Tests",
        "command": "npm run test:integration",
        "timeout": 90000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 8
      },
      {
        "id": "coverage-scripts",
        "name": "Scripts Coverage Check",
        "command": "npm run test:coverage:scripts",
        "timeout": 120000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 9
      },
      {
        "id": "api-e2e-tests",
        "name": "API E2E Tests",
        "command": "npm run test:api-e2e",
        "timeout": 120000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 10
      },
      {
        "id": "typescript-preference",
        "name": "TypeScript Preference Check",
        "command": "node node_modules/.bin/tsx scripts/check-typescript-preference.ts",
        "timeout": 10000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 11
      },
      {
        "id": "ai-code-review",
        "name": "AI Code Review",
        "command": "node node_modules/.bin/tsx src/tools/ai-code-reviewer.ts",
        "timeout": 120000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 12
      },
      {
        "id": "visual-regression",
        "name": "Visual Regression Tests",
        "command": "node scripts/visual-regression.js",
        "timeout": 60000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 13
      },
      {
        "id": "dead-code",
        "name": "Dead Code Detection",
        "command": "node node_modules/.bin/tsx scripts/check-dead-code.ts",
        "timeout": 90000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 14
      },
      {
        "id": "duplication-check",
        "name": "Code Duplication Detection",
        "command": "npm run duplication-check",
        "timeout": 45000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 15
      },
      {
        "id": "vulnerability-check",
        "name": "Dependency Vulnerability Scan",
        "command": "npm audit --audit-level=moderate",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 16
      },
      {
        "id": "playwright-e2e",
        "name": "Playwright E2E Tests",
        "command": "cd ui && npm run test:e2e",
        "timeout": 300000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 17
      },
      {
        "id": "uncommitted-files",
        "name": "Uncommitted Files Check",
        "command": "node node_modules/.bin/tsx scripts/check-uncommitted-files.ts",
        "timeout": 10000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 18
      },
      {
        "id": "todo-list",
        "name": "Todo List Validation",
        "command": "node node_modules/.bin/tsx scripts/validate-todo-list.ts",
        "timeout": 10000,
        "enabled": true,
        "continueOnFailure": false,
        "priority": 19
      }
    ],
    "enableMetrics": true,
    "maxAttempts": 3
  },
  "logging": {
    "level": "info",
    "enableConsole": true,
    "enableFile": true,
    "logsDir": "./logs",
    "accessLogFile": "access.log",
    "appLogFile": "app.log",
    "errorLogFile": "error.log",
    "maxFileSize": "10485760",
    "maxFiles": "10",
    "datePattern": "YYYY-MM-DD"
  }
}
    "enableMetrics": true,
    "maxAttempts": 5
  },
  "logging": {
    "level": "info",
    "enableConsole": true,
    "enableFile": true,
    "logsDir": "./logs",
    "accessLogFile": "access.log",
    "appLogFile": "app.log",
    "errorLogFile": "error.log",
    "maxFileSize": "10485760",
    "maxFiles": "10",
    "datePattern": "YYYY-MM-DD"
  }

#!/usr/bin/env sh
set -e  # Exit immediately if any command fails

echo "🚀 Running pre-commit validation checks from settings.json..."

# Generate a unique session ID for this commit validation
SESSION_ID="husky-precommit-$(date +%s)-$$"

# Run the validation script with session ID
# This reads validation stages from settings.json and runs them sequentially
# with early exit on failure (just like the hardcoded steps before)
npx ts-node scripts/validate-task.ts "$SESSION_ID"
VALIDATION_RESULT=$?

echo ""

if [ $VALIDATION_RESULT -eq 0 ]; then
    echo "🎉 All pre-commit validation checks passed! Commit proceeding..."
    exit 0
else
    echo "❌ Pre-commit validation failed - commit blocked"
    echo "💡 Fix the validation issues above before committing."
    echo "💡 You can run 'npx ts-node scripts/validate-task.ts' to see detailed output."
    exit 1
fi

{
  "name": "codegoat",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:prod": "NODE_ENV=production node dist/src/index.js",
    "test": "jest --config=jest.unit.config.js",
    "test:unit": "npm run test:unit:backend && npm run test:unit:frontend",
    "test:unit:backend": "jest --config=jest.unit.config.js",
    "test:unit:frontend": "cd ui && npm test",
    "test:integration": "jest --config=jest.integration.config.js --passWithNoTests",
    "test:e2e": "cd ui && npm run test:e2e:robust",
    "test:e2e:unified": "cd tests/api-e2e && npx vitest run --config=vitest-unified.config.ts",
    "test:e2e:optimized": "cd tests/api-e2e && npx vitest run --config=vitest-optimized.config.ts",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "jest --config=jest.unit.config.js --coverage",
    "test:coverage:frontend": "cd ui && npm run test:coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "typescript-check": "node scripts/check-typescript-preference.js",
    "logs:clean:optimized": "npx ts-node scripts/optimized-log-cleanup.ts",
    "logs:stats": "npx ts-node scripts/log-stats.ts",
    "quality": "npm run lint && npm run format:check && npm run type-check && npm run typescript-check && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.2.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "dotenv": "^17.2.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "lint-staged": "^16.1.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "express": "^5.1.0",
    "winston": "^3.17.0",
    "zod": "^4.0.17"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}

{
  "name": "codegoat",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "dev:all": "./scripts/dev.sh",
    "dev:status": "./scripts/dev-status.sh",
    "dev:kill": "./scripts/dev-status.sh kill",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:prod": "NODE_ENV=production node dist/src/index.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests src/",
    "test:e2e": "jest --testPathIgnorePatterns=[] tests/",
    "test:e2e:optimized": "cd tests/api-e2e && npx vitest run --config=vitest-optimized.config.ts",
    "test:e2e:unified": "cd tests/api-e2e && npx vitest run --config=vitest-unified.config.ts",
    "test:e2e:single": "jest tests/e2e.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "typescript-check": "node scripts/check-typescript-preference.js",
    "duplication-check": "npx jscpd src/ || echo \"Duplication found but within acceptable threshold\"",
    "logs:clean": "node -e \"const { LogCleaner } = require('./dist/src/utils/log-cleaner'); const { WinstonLogger } = require('./dist/src/logger-winston'); const path = require('path'); const logger = new WinstonLogger({logsDir: path.join(__dirname, 'logs')}); const cleaner = new LogCleaner({logsDir: path.join(__dirname, 'logs'), maxLogFiles: 50, maxLogAge: 30, maxLogSize: 10485760}, logger); cleaner.cleanLogs().then(() => console.log('Logs cleaned successfully')).catch(console.error);\"",
    "logs:clean:optimized": "npx ts-node scripts/optimized-log-cleanup.ts",
    "logs:stats": "npx ts-node scripts/log-stats.ts",
    "logs:migrate": "./scripts/migrate-logs.sh",
    "ai-review": "ts-node src/tools/ai-code-reviewer.ts",
    "todo:validate": "ts-node scripts/validate-todo-list.ts",
    "quality": "npm run lint && npm run format:check && npm run type-check && npm run typescript-check && npm run test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:test:migrate": "dotenv -e .env.test -- prisma migrate dev",
    "db:test:push": "dotenv -e .env.test -- prisma db push",
    "db:test:reset": "dotenv -e .env.test -- prisma migrate reset --force",
    "db:test:studio": "dotenv -e .env.test -- prisma studio",
    "db:test:seed": "dotenv -e .env.test -- prisma db seed",
    "db:setup": "node scripts/database-setup.js setup",
    "db:clean-test-data": "node scripts/database-setup.js clean",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.2.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.2.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "lint-staged": "^16.1.4",
    "nodemon": "^3.1.10",
    "openai": "^5.12.2",
    "pactum": "^3.8.0",
    "prettier": "^3.6.2",
    "socket.io": "^4.8.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@prisma/client": "^6.13.0",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "prisma": "^6.13.0",
    "winston": "^3.17.0",
    "yaml": "^2.8.1",
    "zod": "^4.0.17"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}

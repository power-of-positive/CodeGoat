{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "lib": ["es2018"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "scripts/**/*", "__tests__/**/*"],
  "exclude": ["node_modules", "dist", "ui/**/*", "scripts/test-*.ts", "tests/e2e/**/*", "tests/**/*.spec.ts"]
}

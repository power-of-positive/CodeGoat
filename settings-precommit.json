{
  "fallback": {
    "maxRetries": 5,
    "retryDelay": 1000,
    "enableFallbacks": true,
    "fallbackOnContextLength": true,
    "fallbackOnRateLimit": true,
    "fallbackOnServerError": false
  },
  "validation": {
    "stages": [
      {
        "id": "lint",
        "name": "Code Linting",
        "command": "npm run lint",
        "timeout": 60000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 1
      },
      {
        "id": "typecheck",
        "name": "Type Checking",
        "command": "npm run type-check",
        "timeout": 45000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 2
      },
      {
        "id": "unit-tests-backend",
        "name": "Backend Unit Tests",
        "command": "npm run test:unit:backend",
        "timeout": 45000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 3
      },
      {
        "id": "unit-tests-frontend",
        "name": "Frontend Unit Tests",
        "command": "cd ui && CI=true npm test -- --watchAll=false --no-watch --passWithNoTests --testTimeout=120000 --maxWorkers=1",
        "timeout": 180000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 4
      },
      {
        "id": "integration-tests",
        "name": "Integration Tests",
        "command": "npm run test:integration",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 5
      },
      {
        "id": "backend-coverage",
        "name": "Backend Coverage Check",
        "command": "npm run test:coverage:backend",
        "timeout": 60000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 6
      },
      {
        "id": "frontend-coverage",
        "name": "Frontend Coverage Check",
        "command": "cd ui && npm run test:coverage -- --maxWorkers=1",
        "timeout": 180000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 7
      },
      {
        "id": "scripts-unit-tests",
        "name": "Scripts Unit Tests",
        "command": "npm run test:unit:scripts",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 8
      },
      {
        "id": "scripts-coverage",
        "name": "Scripts Coverage Check",
        "command": "npm run test:coverage:scripts",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 9
      },
      {
        "id": "api-e2e-tests",
        "name": "API E2E Tests",
        "command": "npm run test:api-e2e",
        "timeout": 60000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 10
      },
      {
        "id": "typescript-preference",
        "name": "TypeScript Preference Check",
        "command": "npx ts-node scripts/check-typescript-preference.ts",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 11
      },
      {
        "id": "ai-code-review",
        "name": "AI Code Review",
        "command": "npx ts-node src/tools/ai-code-reviewer.ts",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": true,
        "order": 12
      },
      {
        "id": "dead-code-detection",
        "name": "Dead Code Detection",
        "command": "npx ts-node scripts/check-dead-code.ts",
        "timeout": 60000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 13
      },
      {
        "id": "code-duplication",
        "name": "Code Duplication Detection",
        "command": "npm run duplication-check",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 14
      },
      {
        "id": "security-audit",
        "name": "Dependency Vulnerability Scan",
        "command": "npm audit --audit-level=moderate",
        "timeout": 30000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 15
      },
      {
        "id": "e2e-tests",
        "name": "Playwright E2E Tests",
        "command": "cd ui && SKIP_WEB_SERVER=true npm run test:e2e",
        "timeout": 180000,
        "enabled": false,
        "continueOnFailure": false,
        "order": 16
      },
      {
        "id": "uncommitted-files",
        "name": "Uncommitted Files Check",
        "command": "npx ts-node scripts/check-uncommitted-files.ts",
        "timeout": 10000,
        "enabled": true,
        "continueOnFailure": false,
        "order": 17
      },
      {
        "id": "todo-list",
        "name": "Todo List Validation",
        "command": "npx ts-node scripts/validate-todo-list.ts",
        "timeout": 10000,
        "enabled": false,
        "continueOnFailure": true,
        "order": 18
      }
    ],
    "enableMetrics": true,
    "maxAttempts": 5
  },
  "logging": {
    "level": "info",
    "enableConsole": true,
    "enableFile": true,
    "logsDir": "./logs",
    "accessLogFile": "access.log",
    "appLogFile": "app.log",
    "errorLogFile": "error.log",
    "maxFileSize": "10485760",
    "maxFiles": "10",
    "datePattern": "YYYY-MM-DD"
  }
}

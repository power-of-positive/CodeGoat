# OpenRouter API Key (used for AI code reviewer and OpenRouter stats)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Code Reviewer Configuration
AI_REVIEWER_ENABLED=true
AI_REVIEWER_ENDPOINT=https://openrouter.ai/api/v1
AI_REVIEWER_MODEL=openrouter/anthropic/claude-3.5-sonnet
AI_REVIEWER_MAX_SEVERITY=high

# Alternative: Use OpenAI directly
# OPENAI_API_KEY=your_openai_api_key_here
# AI_REVIEWER_ENDPOINT=https://api.openai.com/v1
# AI_REVIEWER_MODEL=gpt-4

# Log configuration
LOG_LEVEL=info

# Kanban Database Configuration (SQLite for local-first approach)
# Development database
KANBAN_DATABASE_URL="file:./prisma/kanban.db"
# Test database (override in .env.test)
KANBAN_TEST_DATABASE_URL="file:./prisma/kanban-test.db"
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/validate-git-command.sh \"$CLAUDE_TOOL_INPUT_COMMAND\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx scripts/run-all-validation.ts",
            "timeout": 1800000
          }
        ]
      }
    ]
  }
}

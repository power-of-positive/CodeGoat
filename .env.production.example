# Production environment variables
NODE_ENV=production
PORT=3000

# Database Configuration (Standard)
DATABASE_URL="file:./prisma/kanban-prod.db"
# Legacy support - keep in sync with DATABASE_URL
KANBAN_DATABASE_URL="file:./prisma/kanban-prod.db"

# AI Code Reviewer Configuration
AI_REVIEWER_ENABLED=true
AI_REVIEWER_ENDPOINT=https://openrouter.ai/api/v1
AI_REVIEWER_MODEL=openrouter/anthropic/claude-3.5-sonnet
AI_REVIEWER_MAX_SEVERITY=medium

# OpenRouter API Key for AI code reviewer
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Logging
LOG_LEVEL=info

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
